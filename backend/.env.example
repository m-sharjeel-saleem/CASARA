# ---- LLM (Google Gemini) ----
# Get a key at https://aistudio.google.com/apikey — server-side only.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional 2nd key — used automatically when the first hits its daily/RPM quota.
GEMINI_2=
MODEL_REASONING=gemini-2.5-pro
MODEL_FAST=gemini-2.5-flash-lite

# ---- GitHub App (multi-tenant, installable — the production path) ----
# Create the App at https://github.com/settings/apps/new (see docs/GITHUB_APP_SETUP.md).
# If these are set, CASARA authenticates per-installation and many orgs can install it.
GITHUB_APP_ID=
GITHUB_APP_SLUG=                         # the URL slug: github.com/apps/<slug>
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Paste the App private key PEM. In a single-line env UI, replace real newlines with \n.
GITHUB_APP_PRIVATE_KEY=

# ---- GitHub (Personal Access Token mode — fallback for local/single-repo dev) ----
# Used only when the App vars above are empty. PAT with repo + pull_request + statuses scope.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Secret you set on the App/webhook (used to verify signatures). Same value in GitHub + here.
GITHUB_WEBHOOK_SECRET=choose-a-long-random-string

# ---- Policy ----
# Composite risk score (0-10) at or above which a PR is gated (merge blocked).
RISK_GATE_THRESHOLD=7.0
# Max one-click suggested fixes posted per PR (bounds LLM cost).
MAX_AUTOFIXES=3
# Free-tier monthly review cap per installation. 0 = unlimited (no cap). Set e.g. 50 to meter.
FREE_MONTHLY_REVIEWS=0

# ---- Supabase (multi-tenant store; empty = local SQLite) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ---- App ----
# SQLite by default — zero external connections. Point to Postgres later if needed.
DATABASE_PATH=casara.db
CORS_ORIGINS=http://localhost:3000
